generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String?
  provider String  @default("credentials")

  role String @default("USER")

  profile  Profile?
  resumes  Resume[]
  attempts Attempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id String @id @default(uuid())

  college        String?
  branch         String?
  graduationYear Int?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id String @id @default(uuid())

  title    String
  fileUrl  String
  fileType String

  isActive Boolean @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysis ResumeAnalysis?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeAnalysis {
  id String @id @default(uuid())

  skills    Json?
  education Json?
  projects  Json?

  rawText String?

  atsScore      Int?  @default(0)
  missingSkills Json?

  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Test {
  id String @id @default(uuid())

  title String

  duration Int

  modules TestModule[]

  questions Question[]

  attempts Attempt[]

  invitations TestInvitation[]
  isPractice Boolean @default(false)

  createdAt DateTime @default(now())
}

model Question {
  id String @id @default(uuid())

  question String

  optionA String
  optionB String
  optionC String
  optionD String

  correctAnswer String

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Attempt {
  id String @id @default(uuid())

  score          Int
  totalQuestions Int
  percentage     Float

  tabSwitches          Int @default(0)
  fullscreenViolations Int @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model QuestionBank {
  id String @id @default(uuid())

  category String

  question String

  optionA String
  optionB String
  optionC String
  optionD String

  correctAnswer String

  createdAt DateTime @default(now())
}

model TestInvitation {
  id String @id @default(uuid())

  email String

  status String @default("PENDING")

  testId String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([email, testId])
}

model TestModule {
  id String @id @default(uuid())

  module String

  questionCount Int

  testId String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
}