generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SecurityLevel {
  BASIC
  PRO
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum CodingCategory {
  ARRAYS
  STRINGS
  LINKED_LIST
  STACK
  QUEUE
  TREE
  GRAPH
  DP
  GREEDY
  BINARY_SEARCH
  RECURSION
  MATH
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String?
  provider String  @default("credentials")

  role String @default("USER")

  codingTests CodingTest[]
  tests       Test[]

  profile  Profile?
  resumes  Resume[]
  attempts Attempt[]

codingInvitations CodingInvitation[]

codingAttempts CodingAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id String @id @default(uuid())

  college        String?
  branch         String?
  graduationYear Int?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id String @id @default(uuid())

  title    String
  fileUrl  String
  fileType String

  isActive Boolean @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysis ResumeAnalysis?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeAnalysis {
  id String @id @default(uuid())

  skills    Json?
  education Json?
  projects  Json?

  rawText String?

  atsScore      Int?  @default(0)
  missingSkills Json?

  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Test {
  id String @id @default(uuid())

  title String

  duration Int

  securityLevel SecurityLevel @default(BASIC)

  modules TestModule[]

  questions Question[]

  attempts Attempt[]

  invitations TestInvitation[]

  isPractice Boolean @default(false)

  createdById String?
  createdBy    User?   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

model Question {
  id String @id @default(uuid())

  question String

  optionA String
  optionB String
  optionC String
  optionD String

  correctAnswer String

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Attempt {
  id String @id @default(uuid())

  score Int

  totalQuestions Int

  percentage Float

  tabSwitches Int @default(0)

  fullscreenViolations Int @default(0)

  copyAttempts Int @default(0)

  rightClickAttempts Int @default(0)

  proctoringReport ProctoringReport?

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  testId String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model QuestionBank {
  id String @id @default(uuid())

  category String

  question String

  optionA String
  optionB String
  optionC String
  optionD String

  correctAnswer String

  createdAt DateTime @default(now())
}

model TestInvitation {
  id String @id @default(uuid())

  email String

  status String @default("PENDING")

  testId String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([email, testId])
}

model TestModule {
  id String @id @default(uuid())

  module String

  questionCount Int

  testId String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model ProctoringReport {
  id String @id @default(uuid())

  attemptId String @unique

  attempt Attempt @relation(fields: [attemptId], references: [id])

  // Permissions

  cameraEnabled Boolean @default(false)

  microphoneEnabled Boolean @default(false)

  // Existing Violations

  tabSwitches Int @default(0)

  fullscreenViolations Int @default(0)

  idleEvents Int @default(0)

  resizeEvents Int @default(0)

  copyAttempts Int @default(0)

  rightClickAttempts Int @default(0)

  // New PRO Features

  faceMissingEvents Int @default(0)

  multipleFaceEvents Int @default(0)

  noiseWarnings Int @default(0)

  focusLossEvents Int @default(0)

  possibleMultiMonitor Boolean @default(false)

  // Scoring

  riskScore Int @default(0)

  securityScore Int @default(100)

  suspicionLevel String @default("LOW")

  createdAt DateTime @default(now())
}

enum CodingDifficulty {
  EASY
  MEDIUM
  HARD
}

enum CodingSecurityLevel {
  BASIC
  PRO
}

enum OutputValidator {
  EXACT
  IGNORE_ORDER
  SET_COMPARE
  FLOAT_COMPARE
  CUSTOM
}

model CodingTest {
  id String @id @default(uuid())

  title String

  description String?

  duration Int

  securityLevel CodingSecurityLevel

  createdById String

  createdBy User @relation(fields: [createdById], references: [id])

  isActive Boolean @default(true)

  questions CodingTestQuestion[]

  invitations CodingInvitation[]

  attempts CodingAttempt[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model CodingQuestionBank {
  id String @id @default(uuid())

  title String

  slug String @unique

  category String

  

  difficulty CodingDifficulty

  description String

  inputFormat String?

  outputFormat String?

  constraints String?

  examples Json?

  starterCodes Json?

  outputValidator OutputValidator @default(EXACT)

  floatPrecision Int @default(6)

  questions CodingTestQuestion[]

  submissions CodingSubmission[]

  testCases CodingQuestionTestCase[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model CodingQuestionTestCase {
  id String @id @default(uuid())

  questionId String

  question CodingQuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  input String

  expectedOutput String

  explanation String?

  isHidden Boolean @default(false)

  createdAt DateTime @default(now())
}

model CodingTestQuestion {
  id String @id @default(uuid())

  codingTestId String

  questionId String

  order Int

  scoreWeight Int @default(100)

  codingTest CodingTest @relation(fields: [codingTestId], references: [id], onDelete: Cascade)

  question CodingQuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([codingTestId, questionId])
}


model CodingInvitation {
  id String @id @default(uuid())

  codingTestId String
  codingTest CodingTest @relation(fields: [codingTestId], references: [id], onDelete: Cascade)

  
  candidateEmail String

  userId String?
  user User? @relation(fields: [userId], references: [id])

  status String @default("PENDING")

  invitedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([codingTestId, candidateEmail])
}


model CodingAttempt {
  id String @id @default(uuid())

  codingTestId String
  codingTest CodingTest @relation(fields: [codingTestId], references: [id], onDelete: Cascade)

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  candidateEmail String

  status String @default("IN_PROGRESS")

  totalQuestions Int @default(0)

  completedQuestions Int @default(0)

  totalScore Int @default(0)

  percentage Float @default(0)

  startedAt DateTime @default(now())

  submittedAt DateTime?

  createdAt DateTime @default(now())

  // Legacy fields — kept to prevent data loss
  riskScore  Int?     @default(0)
  riskLevel  String?  @default("LOW")

  submissions CodingSubmission[]

  securityEvents CodingSecurityEvent[]


 

  @@unique([codingTestId, userId])
}


model CodingSubmission {
  id String @id @default(uuid())

  attemptId String
  attempt CodingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  questionId String
  question CodingQuestionBank @relation(fields: [questionId], references: [id], onDelete: Cascade)

  language String

  sourceCode String? @db.Text

  status String

  passedCases Int @default(0)

  totalCases Int @default(0)

  score Int @default(0)

  executionTime Float?

  memoryUsed Int?

  submissionNumber Int @default(1)

  createdAt DateTime @default(now())
}

model CodingSecurityEvent {
  id String @id @default(uuid())

  attemptId String
  attempt CodingAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  eventType String

  details Json?

  screenshotUrl String?

  createdAt DateTime @default(now())
}