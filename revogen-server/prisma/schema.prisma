generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SecurityLevel {
  BASIC
  PRO
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum CodingCategory {
  ARRAYS
  STRINGS
  LINKED_LIST
  STACK
  QUEUE
  TREE
  GRAPH
  DP
  GREEDY
  BINARY_SEARCH
  RECURSION
  MATH
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String?
  provider String  @default("credentials")

  role String @default("USER")

  profile     Profile?
  resumes     Resume[]
  attempts    Attempt[]
  submissions CodingSubmission[]

  codingTests CodingTest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id String @id @default(uuid())

  college        String?
  branch         String?
  graduationYear Int?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id String @id @default(uuid())

  title    String
  fileUrl  String
  fileType String

  isActive Boolean @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysis ResumeAnalysis?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeAnalysis {
  id String @id @default(uuid())

  skills    Json?
  education Json?
  projects  Json?

  rawText String?

  atsScore      Int?  @default(0)
  missingSkills Json?

  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Test {
  id String @id @default(uuid())

  title String

  duration Int

  securityLevel SecurityLevel @default(BASIC)

  modules TestModule[]

  questions Question[]

  attempts Attempt[]

  invitations TestInvitation[]

  isPractice Boolean @default(false)

  createdAt DateTime @default(now())
}

model Question {
  id String @id @default(uuid())

  question String

  optionA String
  optionB String
  optionC String
  optionD String

  correctAnswer String

  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Attempt {
  id String @id @default(uuid())

  score Int

  totalQuestions Int

  percentage Float

  tabSwitches Int @default(0)

  fullscreenViolations Int @default(0)

  copyAttempts Int @default(0)

  rightClickAttempts Int @default(0)

  proctoringReport ProctoringReport?

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  testId String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model QuestionBank {
  id String @id @default(uuid())

  category String

  question String

  optionA String
  optionB String
  optionC String
  optionD String

  correctAnswer String

  createdAt DateTime @default(now())
}

model TestInvitation {
  id String @id @default(uuid())

  email String

  status String @default("PENDING")

  testId String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([email, testId])
}

model TestModule {
  id String @id @default(uuid())

  module String

  questionCount Int

  testId String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model ProctoringReport {
  id String @id @default(uuid())

  attemptId String @unique

  attempt Attempt @relation(fields: [attemptId], references: [id])

  // Permissions

  cameraEnabled Boolean @default(false)

  microphoneEnabled Boolean @default(false)

  // Existing Violations

  tabSwitches Int @default(0)

  fullscreenViolations Int @default(0)

  idleEvents Int @default(0)

  resizeEvents Int @default(0)

  copyAttempts Int @default(0)

  rightClickAttempts Int @default(0)

  // New PRO Features

  faceMissingEvents Int @default(0)

  multipleFaceEvents Int @default(0)

  noiseWarnings Int @default(0)

  focusLossEvents Int @default(0)

  possibleMultiMonitor Boolean @default(false)

  // Scoring

  riskScore Int @default(0)

  securityScore Int @default(100)

  suspicionLevel String @default("LOW")

  createdAt DateTime @default(now())
}

model CodingQuestion {
  id String @id @default(uuid())

  title String
  slug  String @unique

  description String @db.Text
  constraints String @db.Text

  inputFormat  String @db.Text
  outputFormat String @db.Text

  difficulty Difficulty
  category   CodingCategory

  starterCode  Json?
  solutionCode String? @db.Text

  timeLimit   Int @default(1000)
  memoryLimit Int @default(256)
  submissions CodingSubmission[]
  testCases CodingTestCase[]

  codingTests CodingTestQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coding_questions")
}

model CodingTestCase {
  id String @id @default(uuid())

  questionId String

  question CodingQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  input          String @db.Text
  expectedOutput String @db.Text

  isHidden Boolean @default(false)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coding_test_cases")
}

model CodingTest {
  id String @id @default(uuid())

  title String

  description String?

  category String?
  isActive Boolean @default(true)

  duration Int

  createdById String

  createdBy User @relation(fields: [createdById], references: [id])

  attempts AssessmentAttempt[]

  questions CodingTestQuestion[]

  assignments CodingAssignment[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("coding_tests")
}

model CodingTestQuestion {
  id String @id @default(uuid())

  codingTestId String

  codingQuestionId String

  marks Int @default(100)

  orderNo Int @default(1)

  codingTest CodingTest @relation(fields: [codingTestId], references: [id], onDelete: Cascade)

  codingQuestion CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)

  @@unique([codingTestId, codingQuestionId])
  @@map("coding_test_questions")
}

model CodingSubmission {
  id String @id @default(uuid())

  codingTestId String
  codingQuestionId String

  codingQuestion CodingQuestion @relation(fields: [codingQuestionId], references: [id], onDelete: Cascade)

  userId String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  candidateEmail String?

  language String

  attemptId String?

  sourceCode String @db.Text

  stdout String? @db.Text

  passedCases Int @default(0)

  totalCases Int @default(0)

  score Int @default(0)

  status String @default("PENDING")

  submittedAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@map("coding_submissions")
}


model SecurityEvent {
  id String @id @default(uuid())

  codingTestId String

  attemptId String?

  eventType String

  details String? @db.Text

  createdAt DateTime @default(now())

  @@map("security_events")
}

model AssessmentAttempt {
  id String @id @default(uuid())

  codingTestId String

  codingTest CodingTest @relation(fields: [codingTestId], references: [id])

  candidateName String?
  candidateEmail String?

  totalQuestions Int

  completedQuestions Int

  totalScore Int

  percentage Int

  securityViolations Int @default(0)

  riskScore Int @default(0)

  riskLevel String @default("LOW")

  status String

  startedAt DateTime @default(now())

  submittedAt DateTime

  createdAt DateTime @default(now())

  @@map("assessment_attempts")
}

model AssessmentQuestionResult {
  id String @id @default(uuid())

  attemptId String

  codingQuestionId String

  questionTitle String

  score Int

  maxScore Int

  passedCases Int

  totalCases Int

  status String

  createdAt DateTime @default(now())

  @@map("assessment_question_results")
}

model CodingAssignment {
  id String @id @default(uuid())

  codingTestId String

  codingTest CodingTest @relation(fields: [codingTestId], references: [id], onDelete: Cascade)

  candidateName String

  candidateEmail String

  accessToken String @unique

  status String @default("PENDING")

  attemptId String?

  createdAt DateTime @default(now())

  @@unique([candidateEmail, codingTestId])

  @@map("coding_assignments")
}